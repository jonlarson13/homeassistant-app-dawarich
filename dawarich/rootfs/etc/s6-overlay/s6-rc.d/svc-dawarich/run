#!/usr/bin/with-contenv bash

export PATH="/usr/lib/postgresql/17/bin:${PATH}"

# Wait for PostgreSQL to be ready
until pg_isready -h localhost -p 5432 -U postgres -q; do
  sleep 1
done

# Create database user and database if they don't exist
DB_USER=$(cat /var/run/s6/container_environment/DATABASE_USERNAME)
DB_NAME=$(cat /var/run/s6/container_environment/DATABASE_NAME)
DB_PASS=$(cat /var/run/s6/container_environment/DATABASE_PASSWORD)

su - postgres -c "PATH=/usr/lib/postgresql/17/bin:\$PATH psql -tc \"SELECT 1 FROM pg_roles WHERE rolname='${DB_USER}'\" | grep -q 1 || PATH=/usr/lib/postgresql/17/bin:\$PATH psql -c \"CREATE ROLE ${DB_USER} WITH LOGIN PASSWORD '${DB_PASS}' CREATEDB;\""
su - postgres -c "PATH=/usr/lib/postgresql/17/bin:\$PATH psql -tc \"SELECT 1 FROM pg_database WHERE datname='${DB_NAME}'\" | grep -q 1 || PATH=/usr/lib/postgresql/17/bin:\$PATH psql -c \"CREATE DATABASE ${DB_NAME} OWNER ${DB_USER};\""
su - postgres -c "PATH=/usr/lib/postgresql/17/bin:\$PATH psql -d ${DB_NAME} -c 'CREATE EXTENSION IF NOT EXISTS postgis;'"

# Symlink storage and public directories to persistent data
rm -rf /var/app/public/uploads
ln -sf /data/dawarich/storage /var/app/storage
ln -sf /data/dawarich/public /var/app/public/uploads

cd /var/app

# Run database migrations
if ! bundle exec rails db:migrate 2>&1; then
  echo "ERROR: Database migration failed! Check logs above."
  exit 1
fi

# Post-upgrade backfill tasks (idempotent, gated by per-version marker).
# 1.7.9: backfill place names and clean up suggested places for the new
# real-time Photon visit/place system. Safe to re-run; only needed once
# per existing install upgrading from <1.7.9.
if [ ! -f /data/dawarich/.post_upgrade_1.7.9 ]; then
  echo "Running 1.7.9 post-upgrade backfill (dawarich:backfill_place_names, dawarich:cleanup_suggested_places)..."
  if bundle exec rails dawarich:backfill_place_names 2>&1 \
     && bundle exec rails dawarich:cleanup_suggested_places 2>&1; then
    touch /data/dawarich/.post_upgrade_1.7.9
    echo "1.7.9 post-upgrade backfill complete."
  else
    echo "WARNING: 1.7.9 post-upgrade backfill failed; will retry on next boot."
  fi
fi

# Create default admin user if it doesn't exist yet
ADMIN_EMAIL=$(cat /var/run/s6/container_environment/ADMIN_EMAIL 2>/dev/null || echo "")
ADMIN_PASSWORD=$(cat /var/run/s6/container_environment/ADMIN_PASSWORD 2>/dev/null || echo "")
if [ -n "$ADMIN_EMAIL" ] && [ -n "$ADMIN_PASSWORD" ]; then
  bundle exec rails runner "
    user = User.find_or_create_by!(email: '${ADMIN_EMAIL}') do |u|
      u.password = '${ADMIN_PASSWORD}'
      u.password_confirmation = '${ADMIN_PASSWORD}'
      puts 'Created default admin user: ${ADMIN_EMAIL}'
    end
    unless user.admin?
      user.update!(admin: true)
      puts 'Granted admin privileges to ${ADMIN_EMAIL}'
    end
    File.write('/data/dawarich/api_key', user.api_key)
    puts \"API key saved to /data/dawarich/api_key\"
  " 2>&1
fi

# --- Per-entity API key setup for multi-user device tracking ---
# The suffix after ":" is a Home Assistant user ID (not a free-text name).
# We build the same "ha-<user_id>@homeassistant.local" email that
# HomeAssistantIngressAuth.user_for() creates when that HA user opens the
# ingress panel, so tracked-entity data lands on the SAME Dawarich account
# the person is auto-logged into, instead of a disconnected local account.
# Find a user's HA ID under Settings, People, Users, click the user;
# the ID is in the URL, e.g. /config/users/edit/<user_id>.
mkdir -p /data/dawarich/api_keys
HA_TRACKED_ENTITIES=$(cat /var/run/s6/container_environment/HA_TRACKED_ENTITIES 2>/dev/null || echo "")
if [ -n "$HA_TRACKED_ENTITIES" ]; then
  # Build list of users to create and entity→key mappings
  declare -A USER_ENTITIES  # ha_user_id → space-separated entity_ids
  ADMIN_ENTITIES=""          # entity_ids that use the admin user

  IFS=',' read -ra ENTITY_LIST <<< "$HA_TRACKED_ENTITIES"
  for entry in "${ENTITY_LIST[@]}"; do
    entry=$(echo "$entry" | xargs)  # trim whitespace
    [ -z "$entry" ] && continue

    if echo "$entry" | grep -q ':'; then
      entity_id="${entry%%:*}"
      raw_id="${entry#*:}"
      raw_id=$(echo "$raw_id" | xargs)  # trim
      # Sanitize: lowercase, only a-z0-9 (HA user IDs are lowercase hex)
      clean_id=$(echo "$raw_id" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]//g')
      if [ -z "$clean_id" ]; then
        # Empty id after sanitization → use admin
        ADMIN_ENTITIES="${ADMIN_ENTITIES} ${entity_id}"
      else
        USER_ENTITIES["$clean_id"]="${USER_ENTITIES[$clean_id]:-} ${entity_id}"
      fi
    else
      ADMIN_ENTITIES="${ADMIN_ENTITIES} ${entry}"
    fi
  done

  # Remove stale API key files from previous config
  rm -f /data/dawarich/api_keys/*

  # Assign admin API key to entities with no id suffix
  ADMIN_API_KEY=$(cat /data/dawarich/api_key 2>/dev/null || echo "")
  for entity_id in $ADMIN_ENTITIES; do
    entity_id=$(echo "$entity_id" | xargs)
    [ -z "$entity_id" ] && continue
    echo -n "$ADMIN_API_KEY" > "/data/dawarich/api_keys/${entity_id}"
    echo "HA Multi-User: ${entity_id} → admin user"
  done

  # Build Ruby script for creating/matching HA-mapped users (single rails runner call)
  if [ ${#USER_ENTITIES[@]} -gt 0 ]; then
    RUBY_SCRIPT=""

    for ha_user_id in "${!USER_ENTITIES[@]}"; do
      email="ha-${ha_user_id}@homeassistant.local"
      password="changemeplease"
      entities="${USER_ENTITIES[$ha_user_id]}"

      RUBY_SCRIPT+="begin\n"
      RUBY_SCRIPT+="  user = User.find_or_create_by!(email: '${email}') do |u|\n"
      RUBY_SCRIPT+="    u.password = '${password}'\n"
      RUBY_SCRIPT+="    u.password_confirmation = '${password}'\n"
      RUBY_SCRIPT+="    puts 'Created user: ${email} (default password: ${password})'\n"
      RUBY_SCRIPT+="  end\n"
      for entity_id in $entities; do
        entity_id=$(echo "$entity_id" | xargs)
        [ -z "$entity_id" ] && continue
        RUBY_SCRIPT+="  File.write('/data/dawarich/api_keys/${entity_id}', user.api_key)\n"
        RUBY_SCRIPT+="  puts 'API key for ${entity_id} → ${email}'\n"
      done
      RUBY_SCRIPT+="rescue => e\n"
      RUBY_SCRIPT+="  puts \"Error creating user ${email}: #{e.message}\"\n"
      RUBY_SCRIPT+="end\n"
    done

    echo -e "$RUBY_SCRIPT" | bundle exec rails runner - 2>&1
  fi

  echo "HA Multi-User: API key setup complete ($(ls /data/dawarich/api_keys/ | wc -l) entities)"
fi

# Precompile assets if needed
if [ ! -f /data/dawarich/.assets_precompiled ] || [ "$DAWARICH_VERSION_CHANGED" = "true" ]; then
  bundle exec rails assets:precompile 2>&1
  touch /data/dawarich/.assets_precompiled
fi

exec bundle exec rails server -b 0.0.0.0 -p 3000
